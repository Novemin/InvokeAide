{
  "name": "invokeaide",
  "version": "0.0.0",
  "private": true,
  "description": "InvokeAide(秘書召喚アプリ)— Vue 3 + Vite + TypeScript ベース、コーチング機能を持つ AI 秘書 PWA",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\" \"tests/**/*.{ts,vue,json}\"",
    "check:legal": "node scripts/check-legal-expressions.js",
    "check:coaching": "node scripts/check-coaching-prompts.js",
    "check:skipped": "node scripts/check-skipped-tests.js",
    "check:all": "npm run lint && npm run typecheck && npm run check:legal && npm run check:coaching && npm run check:skipped && npm run test",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.0",
    "jsdom": "^24.0.0",
    "msw": "^2.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "vue-tsc": "^2.2.12"
  }
}
